APP_NAME=Pokeleximon API
APP_ENV=prod
APP_VERSION=0.1.0
TIMEZONE=Europe/London
ADMIN_AUTH_ENABLED=true
ADMIN_AUTH_TOKEN=replace-with-strong-random-token
ADMIN_AUTH_HEADER_NAME=X-Admin-Token
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PUBLIC_MAX_REQUESTS=180
RATE_LIMIT_PUBLIC_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_MAX_REQUESTS=60
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60
RATE_LIMIT_TRUST_X_FORWARDED_FOR=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_ENVIRONMENT=prod
SENTRY_RELEASE=0.1.0
SCHEDULER_ENABLED=true
PUBLISH_ON_STARTUP=true
RESERVE_MIN_COUNT=5
RESERVE_TARGET_COUNT=30
RESERVE_TOPUP_INTERVAL_MINUTES=60
GENERATOR_ENABLED=true
FEATURE_CONNECTIONS_ENABLED=false
ALERT_WEBHOOK_ENABLED=true
ALERT_WEBHOOK_URL=https://your-pipedream-endpoint.m.pipedream.net
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
POKEAPI_REFRESH_ENABLED=true
POKEAPI_REFRESH_ON_STARTUP=false
POKEAPI_REFRESH_CRON="25 2 * * *"
POKEAPI_REFRESH_WORKDIR=/opt/pokeleximon/services/crossword-gen
POKEAPI_REFRESH_COMMAND="bash -lc 'python3 scripts/build_wordlist.py && python3 scripts/build_crossword_wordlist.py && python3 scripts/build_detail_corpus.py --fetch-missing --request-delay-seconds 0.05 && python3 scripts/rebuild_crossword_answer_clue_csv.py && python3 scripts/build_crossword_clue_variants.py --cache-only --strict-min-clues --min-clues-per-answer 3 --max-clues-per-answer 5'"
POKEAPI_REFRESH_TIMEOUT_SECONDS=10800
ARTIFACT_STORAGE_ENABLED=true
ARTIFACT_STORAGE_BACKEND=s3
ARTIFACT_STORAGE_DIR=/tmp/pokeleximon-artifacts
ARTIFACT_PUBLIC_BASE_URL=
ARTIFACT_S3_BUCKET=your-artifact-bucket
ARTIFACT_S3_PREFIX=artifacts
ARTIFACT_S3_REGION=eu-west-2
ARTIFACT_S3_ENDPOINT_URL=
ARTIFACT_S3_ACCESS_KEY_ID=
ARTIFACT_S3_SECRET_ACCESS_KEY=
ARTIFACT_S3_SESSION_TOKEN=
ARTIFACT_S3_ADDRESSING_STYLE=
ARTIFACT_S3_PRESIGN_TTL_SECONDS=0
CROSSWORD_CSV_PATH=/opt/pokeleximon/data/wordlist_crossword_answer_clue.csv
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pokeleximon
REDIS_URL=redis://localhost:6379/0
