APP_NAME=Pokeleximon API
APP_ENV=dev
APP_VERSION=0.1.0
TIMEZONE=Europe/London
ADMIN_AUTH_ENABLED=true
ADMIN_AUTH_TOKEN=local-admin-token-change-me
ADMIN_AUTH_HEADER_NAME=X-Admin-Token
FEATURE_CONNECTIONS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PUBLIC_MAX_REQUESTS=180
RATE_LIMIT_PUBLIC_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_MAX_REQUESTS=60
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60
RATE_LIMIT_TRUST_X_FORWARDED_FOR=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_ENVIRONMENT=dev
SENTRY_RELEASE=0.1.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pokeleximon
REDIS_URL=redis://localhost:6379/0
ALERT_WEBHOOK_ENABLED=true
ALERT_WEBHOOK_URL=https://eozm8x14lg2uaev.m.pipedream.net
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
POKEAPI_REFRESH_ENABLED=true
POKEAPI_REFRESH_ON_STARTUP=false
POKEAPI_REFRESH_CRON="25 2 * * *"
POKEAPI_REFRESH_WORKDIR=/Users/ben.hutchinson/code/pokeleximon/services/crossword-gen
POKEAPI_REFRESH_COMMAND="bash -lc 'python3 scripts/build_wordlist.py && python3 scripts/build_crossword_wordlist.py && python3 scripts/build_detail_corpus.py --fetch-missing --request-delay-seconds 0.05 && python3 scripts/rebuild_crossword_answer_clue_csv.py && python3 scripts/build_crossword_clue_variants.py --cache-only --strict-min-clues --min-clues-per-answer 3 --max-clues-per-answer 5'"
POKEAPI_REFRESH_TIMEOUT_SECONDS=10800
