APP_NAME=Pokeleximon API
APP_ENV=dev
APP_VERSION=0.1.0
TIMEZONE=Europe/London
ADMIN_AUTH_ENABLED=true
ADMIN_AUTH_TOKEN=change-me-admin-token
ADMIN_AUTH_HEADER_NAME=X-Admin-Token
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PUBLIC_MAX_REQUESTS=180
RATE_LIMIT_PUBLIC_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_MAX_REQUESTS=60
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60
RATE_LIMIT_TRUST_X_FORWARDED_FOR=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_ENVIRONMENT=dev
SENTRY_RELEASE=0.1.0
SCHEDULER_ENABLED=true
PUBLISH_ON_STARTUP=true
DRAFT_GENERATION_ENABLED=true
DRAFT_GENERATION_CRON="0 9 * * *"
RESERVE_MIN_COUNT=5
RESERVE_TARGET_COUNT=30
RESERVE_TOPUP_INTERVAL_MINUTES=60
GENERATOR_ENABLED=true
FEATURE_CONNECTIONS_ENABLED=false
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
POKEAPI_REFRESH_ENABLED=false
POKEAPI_REFRESH_ON_STARTUP=false
POKEAPI_REFRESH_CRON="15 2 * * *"
POKEAPI_REFRESH_COMMAND=
POKEAPI_REFRESH_WORKDIR=
POKEAPI_REFRESH_TIMEOUT_SECONDS=7200
ARTIFACT_STORAGE_ENABLED=false
ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_STORAGE_DIR=/tmp/pokeleximon-artifacts
ARTIFACT_PUBLIC_BASE_URL=
ARTIFACT_S3_BUCKET=
ARTIFACT_S3_PREFIX=artifacts
ARTIFACT_S3_REGION=eu-west-2
ARTIFACT_S3_ENDPOINT_URL=
ARTIFACT_S3_ACCESS_KEY_ID=
ARTIFACT_S3_SECRET_ACCESS_KEY=
ARTIFACT_S3_SESSION_TOKEN=
ARTIFACT_S3_ADDRESSING_STYLE=
ARTIFACT_S3_PRESIGN_TTL_SECONDS=0
CROSSWORD_CSV_PATH=/app/data/wordlist_crossword_answer_clue.csv
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pokeleximon
REDIS_URL=redis://localhost:6379/0
